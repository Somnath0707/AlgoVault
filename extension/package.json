{
  "name": "algovault",
  "displayName": "AlgoVault",
  "version": "0.1.0",
  "description": "Your competitive programming operating system",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.6.2",
    "@plasmohq/storage": "^1.11.0",
    "lucide-react": "^0.395.0",
    "plasmo": "0.89.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/chrome": "0.0.268",
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "sharp": "^0.35.2",
    "svgo": "^3.3.3",
    "tailwindcss": "^3.4.4",
    "typescript": "5.4.5"
  },
  "manifest": {
    "permissions": [
      "sidePanel",
      "storage",
      "activeTab",
      "cookies"
    ],
    "host_permissions": [
      "https://leetcode.com/*",
      "https://raw.githubusercontent.com/*",
      "https://api.github.com/*",
      "https://api.entranthub.com/*",
      "http://localhost:8080/*"
    ],
    "web_accessible_resources": [
      {
        "resources": ["assets/*"],
        "matches": ["https://leetcode.com/*"]
      }
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
